# HN-Agent 环境变量配置示例
# 复制为 .env 并填入实际值

# OpenAI API Key
HN_AGENT_MODEL__PROVIDERS__OPENAI__API_KEY=sk-your-openai-key

# Anthropic API Key（可选）
# HN_AGENT_MODEL__PROVIDERS__ANTHROPIC__API_KEY=sk-ant-your-key

# DeepSeek API Key（可选）
# HN_AGENT_MODEL__PROVIDERS__DEEPSEEK__API_KEY=your-deepseek-key

# 调试模式
# HN_AGENT_APP__DEBUG=true
